# Doctor Service Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# MICROSERVICE PATTERN:
#   Each microservice in MediLink connects to the SAME MongoDB Atlas cluster,
#   but uses its OWN database (e.g. /doctor-service, /patient-service).
#   This keeps data isolated per service while sharing infrastructure.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3003

# Replace <username> and <password> with your Atlas credentials.
# The database name "doctor-service" is intentional — do NOT use the cluster root.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.ytfzhlz.mongodb.net/doctor-service?retryWrites=true&w=majority&appName=Cluster0

# Must match the JWT_SECRET used in auth-service so tokens are verifiable here.
JWT_SECRET=your_shared_jwt_secret_here
JWT_EXPIRE_IN=1d

NODE_ENV=development
